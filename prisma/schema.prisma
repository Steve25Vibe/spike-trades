generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// SPIKE TRADES — Database Schema
// ============================================

// ---- User & Auth ----

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  role              String    @default("user") // "admin" | "user"
  mustChangePassword Boolean  @default(false)
  sessionVersion    Int       @default(1)

  // Email preferences (auto-enrolled, opt-out)
  emailDailySpikes    Boolean @default(true)
  emailSellReminders  Boolean @default(true)
  emailDeviationAlerts Boolean @default(true)
  emailOpeningBell     Boolean  @default(true)
  emailRadar           Boolean  @default(true)

  lastLoginAt       DateTime?
  lastSeenAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  portfolios        Portfolio[]
  sessions          UserSession[]
  invitationUsed    Invitation? @relation("UsedBy")

  @@index([email])
}

model Invitation {
  id          String   @id @default(cuid())
  code        String   @unique
  email       String
  status      String   @default("pending") // pending, accepted, expired
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  usedAt      DateTime?
  usedById    String?  @unique
  usedBy      User?    @relation("UsedBy", fields: [usedById], references: [id])

  @@index([code])
  @@index([email])
}

model UserSession {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  loginAt         DateTime  @default(now())
  logoutAt        DateTime?
  duration        Int?      // seconds
  lastHeartbeatAt DateTime?

  @@index([userId])
  @@index([loginAt])
  @@index([lastHeartbeatAt])
}

// ---- Market Data ----

model DailyReport {
  id            String   @id @default(cuid())
  date          DateTime @db.Date
  generatedAt   DateTime @default(now())
  marketRegime  String?  // bull, bear, neutral, volatile
  tsxLevel      Float?
  tsxChange     Float?
  oilPrice      Float?
  goldPrice     Float?
  btcPrice      Float?
  cadUsd        Float?
  councilLog    Json?    // Full LLM council conversation
  csvUrl        String?  // Path to downloadable CSV
  spikes        Spike[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([date])
  @@index([date])
}

model OpeningBellReport {
  id             String   @id @default(cuid())
  date           DateTime @db.Date
  generatedAt    DateTime @default(now())
  sectorSnapshot Json?
  tickersScanned Int
  scanDurationMs Int
  picks          OpeningBellPick[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([date])
  @@index([date])
}

model OpeningBellPick {
  id               String   @id @default(cuid())
  reportId         String
  report           OpeningBellReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  rank             Int
  ticker           String
  name             String
  sector           String?
  exchange         String
  priceAtScan      Float
  previousClose    Float
  changePercent    Float
  relativeVolume   Float
  sectorMomentum   Float?
  momentumScore    Float
  intradayTarget   Float
  keyLevel         Float
  conviction       String
  rationale        String?  @db.Text

  // Accuracy fields — filled after market close
  actualHigh       Float?
  actualClose      Float?
  targetHit        Boolean?
  keyLevelBroken   Boolean?

  // Token usage for cost tracking
  tokenUsage       Json?

  portfolioEntries PortfolioEntry[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([reportId])
  @@index([ticker, createdAt])
}

model Spike {
  id              String   @id @default(cuid())
  reportId        String
  report          DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  rank            Int
  ticker          String   // e.g. "RY.TO"
  name            String
  sector          String?
  exchange        String   // TSX or TSXV

  // Current data
  price           Float
  volume          Int
  avgVolume       Int?
  marketCap       Float?

  // Spike Score breakdown
  spikeScore      Float    // 0-100 composite
  momentumScore   Float?
  volumeScore     Float?
  technicalScore  Float?
  macroScore      Float?
  sentimentScore  Float?
  shortInterest   Float?
  volatilityAdj   Float?
  sectorRotation  Float?
  patternMatch    Float?
  liquidityDepth  Float?   // Creative factor 1
  insiderSignal   Float?   // Creative factor 2
  gapPotential    Float?   // Creative factor 3
  convictionScore Float?   // Council conviction (0-10)

  // Predictions
  predicted3Day   Float    // % return
  predicted5Day   Float
  predicted8Day   Float
  confidence      Float    // 0-100%

  // Actuals (filled after market close)
  actual3Day      Float?
  actual5Day      Float?
  actual8Day      Float?

  // Narrative
  narrative       String?  @db.Text // LLM-generated analysis

  // Historical calibration
  historicalConfidence Float?   // calibrated confidence from backtest (0-100)
  calibrationSamples  Int?     // number of historical samples
  overconfidenceFlag  Boolean? // true if council >> history
  institutionalConvictionScore Int?    // IIC 0-100; null for legacy rows

  // Learning engine adjustments
  learningAdjustments String?  // JSON blob of per-pick learning adjustments

  // Technical indicators snapshot
  rsi             Float?
  macd            Float?
  macdSignal      Float?
  adx             Float?
  bollingerUpper  Float?
  bollingerLower  Float?
  ema3            Float?
  ema8            Float?
  atr             Float?

  // Portfolio locks
  portfolioEntries PortfolioEntry[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([reportId])
  @@index([ticker, createdAt])
  @@index([spikeScore])
}

model Portfolio {
  id            String   @id @default(cuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  name          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Sizing settings (per-portfolio)
  sizingMode    String   @default("manual")    // auto, fixed, manual
  portfolioSize Float    @default(100000)
  fixedAmount   Float    @default(2500)
  kellyMaxPct   Float    @default(2)
  kellyWinRate  Float    @default(0.6)

  entries       PortfolioEntry[]

  @@index([userId])
  @@index([createdAt])
}

model PortfolioEntry {
  id              String   @id @default(cuid())
  portfolioId     String?
  portfolio       Portfolio? @relation(fields: [portfolioId], references: [id])
  spikeId            String?
  spike              Spike? @relation(fields: [spikeId], references: [id])
  openingBellPickId  String?
  openingBellPick    OpeningBellPick? @relation(fields: [openingBellPickId], references: [id])
  radarPickId        String?
  radarPick          RadarPick? @relation(fields: [radarPickId], references: [id])
  ticker          String
  name            String

  // Entry
  entryPrice      Float
  entryDate       DateTime
  shares          Int
  positionSize    Float    // Dollar amount
  positionPct     Float    // % of portfolio

  // Targets
  target3Day      Float?
  target5Day      Float?
  target8Day      Float?
  stopLoss        Float?

  // Exit
  exitPrice       Float?
  exitDate        DateTime?
  exitReason      String?  // target_hit, stop_loss, manual, deviation_alert

  // P&L
  realizedPnl     Float?
  realizedPnlPct  Float?

  // Alerts
  alertSent3Day   Boolean  @default(false)
  alertSent5Day   Boolean  @default(false)
  alertSent8Day   Boolean  @default(false)
  deviationAlert  Boolean  @default(false)

  status          String   @default("active") // active, closed, stopped

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([portfolioId])
  @@index([openingBellPickId])
  @@index([radarPickId])
  @@index([status])
  @@index([ticker])
  @@index([entryDate])
}

model AccuracyRecord {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  horizon         Int      // 3, 5, or 8 days

  // Aggregate metrics
  totalPredictions Int
  correctDirection Int     // Predicted direction matches actual
  meanAbsError    Float    // MAE
  meanError       Float    // Bias
  hitRate         Float    // % correct direction
  avgPredicted    Float
  avgActual       Float
  correlation     Float?   // Pred vs actual correlation

  createdAt       DateTime @default(now())

  @@unique([date, horizon])
  @@index([date])
}

model MarketRegime {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  regime          String   // bull, bear, neutral, volatile
  vixLevel        Float?
  tsxTrend        String?  // up, down, sideways
  sectorLeader    String?
  oilTrend        String?
  goldTrend       String?
  cadStrength     Float?
  notes           String?  @db.Text

  createdAt       DateTime @default(now())

  @@unique([date])
}

model ApiLog {
  id              String   @id @default(cuid())
  source          String   // fmp, polygon, eodhd, yfinance
  endpoint        String
  status          Int      // HTTP status
  responseTimeMs  Int
  error           String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([source, createdAt])
}

model CouncilLog {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  claudeAnalysis  Json?
  grokAnalysis    Json?
  finalVerdict    Json?
  consensusScore  Float?   // How much models agreed
  processingTime  Int?     // ms

  createdAt       DateTime @default(now())

  @@unique([date])
}

// ---- Radar (Pre-Market Smart Money Flow) ----

model RadarReport {
  id             String      @id @default(cuid())
  date           DateTime    @unique
  generatedAt    DateTime    @default(now())
  tickersScanned Int
  tickersFlagged Int
  scanDurationMs Int
  tokenUsage     Json?
  picks          RadarPick[]

  @@index([date])
}

model RadarPick {
  id                String      @id @default(cuid())
  reportId          String
  report            RadarReport @relation(fields: [reportId], references: [id])
  rank              Int
  ticker            String
  name              String      @default("")
  sector            String?
  exchange          String
  priceAtScan       Float
  smartMoneyScore   Int
  catalystStrength  Int
  newsSentiment     Int
  technicalSetup    Int
  volumeSignals     Int
  sectorAlignment   Int
  rationale         String?     @db.Text
  topCatalyst       String?
  passedOpeningBell Boolean     @default(false)
  passedSpikes      Boolean     @default(false)

  // Accuracy tracking — backfilled at 4:30 PM
  actualOpenPrice     Float?    // Opening price on scan day
  actualOpenChangePct Float?    // % change from previous close to open
  actualDayHigh       Float?    // Highest price during the day
  actualDayClose      Float?    // Closing price
  openMoveCorrect     Boolean?  // Did ticker move in predicted direction at open?
  portfolioEntries    PortfolioEntry[]

  @@index([reportId])
  @@index([ticker])
}

model CouncilConfig {
  id                String   @id @default("singleton")
  minAdvDollars     Int      @default(5000000)
  updatedAt         DateTime @updatedAt
  updatedByUserId   String?
  updatedByEmail    String?
}
