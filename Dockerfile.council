FROM python:3.12-slim

WORKDIR /app

# Install dependencies
COPY requirements-council.txt .
RUN pip install --no-cache-dir -r requirements-council.txt

# Copy brain + API server + portfolio interface
COPY canadian_llm_council_brain.py .
COPY canadian_portfolio_interface.py .
COPY api_server.py .
COPY fmp_bulk_cache.py .
COPY eodhd_news.py .
# Sibling B modules (PR #15)
COPY eodhd_enrichment.py .
COPY us_dual_listing_enrichment.py .
COPY cross_compare.py .
COPY dual_listing_map.json .

EXPOSE 8100

CMD ["uvicorn", "api_server:app", "--host", "0.0.0.0", "--port", "8100"]
