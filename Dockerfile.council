FROM python:3.12-slim

WORKDIR /app

# Install dependencies
COPY requirements-council.txt .
RUN pip install --no-cache-dir -r requirements-council.txt

# Copy brain + API server + portfolio interface
COPY canadian_llm_council_brain.py .
COPY canadian_portfolio_interface.py .
COPY api_server.py .

EXPOSE 8100

CMD ["uvicorn", "api_server:app", "--host", "0.0.0.0", "--port", "8100"]
