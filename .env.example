# ============================================
# SPIKE TRADES — Environment Configuration
# ============================================
# Droplet: 147.182.150.30
# Domain:  spiketrades.ca
# Path:    /opt/spike-trades
# ============================================
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.

# --- App ---
NEXT_PUBLIC_APP_URL=https://spiketrades.ca
NODE_ENV=production
APP_PASSWORD_HASH=  # bcrypt hash of 'godmode' — auto-generated on first run if empty

# --- Database ---
DATABASE_URL=postgresql://spiketrades:YOUR_DB_PASSWORD@db:5432/spiketrades?schema=public
DB_PASSWORD=  # Generate: openssl rand -hex 16

# --- Financial Data APIs ---
FMP_API_KEY=YOUR_FMP_PROFESSIONAL_KEY
FINNHUB_API_KEY=YOUR_FINNHUB_KEY

# --- LLM Council (4-Stage Pipeline) ---
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY          # Claude Sonnet 4.6 + Opus 4.6
XAI_API_KEY=YOUR_XAI_GROK_KEY                # SuperGrok Heavy

# Vertex AI (replaces Gemini public API)
GCP_PROJECT_ID=gen-lang-client-0879620722
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/spiketrades-sa.json  # Vertex AI service account

# --- Email (Resend) ---
RESEND_API_KEY=YOUR_RESEND_KEY
EMAIL_FROM=alerts@spiketrades.ca
EMAIL_TO=steve@boomerang.energy

# --- Council Brain API ---
COUNCIL_API_URL=http://localhost:8100     # FastAPI server for Python council brain

# --- Scheduling ---
CRON_TIMEZONE=America/Halifax
ANALYSIS_CRON_HOUR=10
ANALYSIS_CRON_MINUTE=45

# --- Security ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
SESSION_SECRET=  # Generate: openssl rand -hex 32

# --- DigitalOcean ---
DO_DROPLET_IP=147.182.150.30
DOMAIN=spiketrades.ca
